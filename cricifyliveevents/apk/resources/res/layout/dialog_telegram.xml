<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_view"
        android:focusable="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/_5sdp"
        android:layout_marginRight="@dimen/_5sdp"
        android:layout_centerInParent="true"
        android:layout_marginHorizontal="@dimen/_5sdp"
        app:cardCornerRadius="10dp"
        app:strokeColor="@color/app_color"
        app:strokeWidth="@dimen/_1sdp">
        <LinearLayout
            android:gravity="end"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="@dimen/_12sdp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/_15sdp"
                android:paddingEnd="@dimen/_12sdp">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:backgroundTint="@color/white"
                    app:cardCornerRadius="@dimen/_100sdp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/telegram"/>
                </com.google.android.material.card.MaterialCardView>
                <TextView
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Join Our Telegram"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
            <TextView
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="15dp"
                android:text="Stay connected with the latest sports updates and exclusive content by joining our Telegram channel."/>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <Button
                    android:textSize="@dimen/_10ssp"
                    android:textColor="@color/app_color"
                    android:id="@+id/donot_show_btn"
                    android:background="@android:color/transparent"
                    android:paddingTop="@dimen/_2sdp"
                    android:paddingBottom="@dimen/_2sdp"
                    android:focusable="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_2sdp"
                    android:layout_marginBottom="@dimen/_2sdp"
                    android:text="Do&apos;nt show"
                    android:layout_marginVertical="@dimen/_2sdp"
                    android:paddingVertical="@dimen/_2sdp"/>
                <Button
                    android:textSize="@dimen/_10ssp"
                    android:textColor="@color/app_color"
                    android:id="@+id/later_btn"
                    android:background="@android:color/transparent"
                    android:paddingTop="@dimen/_2sdp"
                    android:paddingBottom="@dimen/_2sdp"
                    android:focusable="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_2sdp"
                    android:layout_marginBottom="@dimen/_2sdp"
                    android:text="Later"
                    android:layout_marginVertical="@dimen/_2sdp"
                    android:paddingVertical="@dimen/_2sdp"/>
                <Button
                    android:textSize="@dimen/_10ssp"
                    android:textColor="@color/app_color"
                    android:id="@+id/join_tg_btn"
                    android:background="@android:color/transparent"
                    android:paddingLeft="@dimen/_22sdp"
                    android:paddingRight="@dimen/_22sdp"
                    android:focusable="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_2sdp"
                    android:layout_marginBottom="@dimen/_2sdp"
                    android:text="Join"
                    android:layout_marginVertical="@dimen/_2sdp"
                    android:paddingHorizontal="@dimen/_22sdp"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</RelativeLayout>
