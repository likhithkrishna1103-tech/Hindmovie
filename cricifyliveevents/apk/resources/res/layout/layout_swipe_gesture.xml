<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeIndicatorCardView"
    android:visibility="gone"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardCornerRadius="10dp">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="15dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/swipeImageView"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:src="@drawable/ic_brightness_medium"/>
        <TextView
            android:textSize="21sp"
            android:textColor="@color/white"
            android:id="@+id/swipeTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="20:35"
            android:layout_marginStart="10dp"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
