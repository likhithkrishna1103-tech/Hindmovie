<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="@dimen/_20sdp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="@dimen/_17ssp"
        android:textColor="@color/white"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Floating Player"/>
    <TextView
        android:textSize="@dimen/_12ssp"
        android:textColor="@color/white"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_8sdp"
        android:text="Enable this option to use directly floating player for playing streams. You can also select multiple floating Players at once."/>
    <androidx.appcompat.widget.SwitchCompat
        android:textSize="@dimen/_11sdp"
        android:textStyle="bold"
        android:id="@+id/enable_sw"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_5sdp"
        android:text="Floating Player"/>
    <TextView
        android:textSize="@dimen/_14ssp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_3sdp"
        android:text="Max Floating Windows"
        android:alpha="0.7"/>
    <Spinner
        android:entries="@array/multi_floatings"
        android:id="@+id/sp"
        android:clickable="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_13sdp"
        android:spinnerMode="dropdown"
        android:alpha="0.5"/>
</LinearLayout>
