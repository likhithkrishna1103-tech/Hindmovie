<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="@dimen/_5sdp"
    android:paddingBottom="@dimen/_5sdp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/_15sdp"
    android:paddingEnd="@dimen/_15sdp">
    <ImageView
        android:id="@+id/search_img"
        android:focusable="true"
        android:visibility="gone"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:alpha="0.7"
        android:layout_marginEnd="@dimen/_5sdp"
        app:srcCompat="@drawable/search_24px"/>
    <EditText
        android:textColor="@color/white"
        android:textColorHint="#ffbbbbbb"
        android:id="@+id/search_view"
        android:focusable="true"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Search"/>
    <ImageButton
        android:id="@+id/menu_btn"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/menu_24px"/>
    <com.google.android.material.button.MaterialButton
        android:textColor="@color/white"
        android:id="@+id/events_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/live_events"
        android:textAllCaps="false"
        android:layout_marginStart="@dimen/_5sdp"
        style="@style/Widget.MaterialComponents.Button.TextButton"/>
    <com.google.android.material.button.MaterialButton
        android:textColor="@color/white"
        android:id="@+id/sports_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sports"
        android:textAllCaps="false"
        android:layout_marginStart="@dimen/_5sdp"
        style="@style/Widget.MaterialComponents.Button.TextButton"/>
    <com.google.android.material.button.MaterialButton
        android:textColor="@color/white"
        android:id="@+id/cats_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Categories"
        android:textAllCaps="false"
        android:layout_marginStart="@dimen/_5sdp"
        style="@style/Widget.MaterialComponents.Button.TextButton"/>
    <com.google.android.material.button.MaterialButton
        android:textColor="@color/white"
        android:id="@+id/fav_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Favourites"
        android:textAllCaps="false"
        android:layout_marginStart="@dimen/_5sdp"
        style="@style/Widget.MaterialComponents.Button.TextButton"/>
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1"/>
    <TextView
        android:ellipsize="end"
        android:id="@+id/title_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/_10sdp"
        android:layout_marginRight="@dimen/_10sdp"
        android:text="@string/app_name"
        android:singleLine="true"/>
    <ImageButton
        android:id="@+id/refresh_btn"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="@dimen/_10sdp"
        android:src="@drawable/refresh_24px"
        android:textAllCaps="false"/>
    <ImageButton
        android:id="@+id/search_btn"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/search_24px"
        android:textAllCaps="false"/>
</LinearLayout>
