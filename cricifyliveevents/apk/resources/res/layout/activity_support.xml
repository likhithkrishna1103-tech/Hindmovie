<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/main_bg"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_width="@dimen/_30sdp"
                    android:layout_height="@dimen/_30sdp"
                    android:layout_marginTop="@dimen/_2sdp"
                    android:src="@drawable/icon"
                    android:layout_marginEnd="@dimen/_10sdp"/>
                <TextView
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CricFy"/>
            </LinearLayout>
            <TextView
                android:textSize="12sp"
                android:textColor="#ffffff"
                android:id="@+id/btnGetApp"
                android:background="@drawable/glass_card_bg"
                android:paddingLeft="16dp"
                android:paddingTop="6dp"
                android:paddingRight="16dp"
                android:paddingBottom="6dp"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Get APP"
                android:layout_alignParentEnd="true"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"/>
        </RelativeLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/glass_card_bg"
            android:padding="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#facc15"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="We Need Your Support"/>
            <TextView
                android:textSize="14sp"
                android:textColor="#94a3b8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Help us keep CricFy running"/>
            <TextView
                android:textSize="11sp"
                android:textColor="#64748b"
                android:id="@+id/tvSupportMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Wait time: 15s • Trigger: every 12h • Auto close: ON"/>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/btnClickHere"
                android:background="@drawable/bg_button_premium"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="30dp"
                android:layout_marginRight="20dp"
                android:foreground="?attr/selectableItemBackground"
                android:contentDescription="Click here to open advertisement"
                android:elevation="8dp"
                android:layout_marginHorizontal="20dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <TextView
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#ffffffff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Click Here"/>
                <TextView
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff00"
                    android:id="@+id/tvAdFrequency"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Open 1 AD per 12h"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/glass_card_bg"
            android:padding="16dp"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">
            <TextView
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Instructions —"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:background="@drawable/step_item_bg"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">
                <TextView
                    android:textStyle="bold"
                    android:textColor="#2dd4bf"
                    android:gravity="center"
                    android:background="@drawable/glass_card_bg"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="1"/>
                <TextView
                    android:textColor="#e2e8f0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Click the button above ☝️"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:background="@drawable/step_item_bg"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">
                <TextView
                    android:textStyle="bold"
                    android:textColor="#2dd4bf"
                    android:gravity="center"
                    android:background="@drawable/glass_card_bg"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="2"/>
                <TextView
                    android:textColor="#e2e8f0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Wait for page to load ��"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:background="@drawable/step_item_bg"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">
                <TextView
                    android:textStyle="bold"
                    android:textColor="#2dd4bf"
                    android:gravity="center"
                    android:background="@drawable/glass_card_bg"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="3"/>
                <TextView
                    android:textColor="#e2e8f0"
                    android:id="@+id/inst_wait_seconds_txt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stay on the page for 12 seconds ♥️"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:background="@drawable/step_item_bg"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">
                <TextView
                    android:textStyle="bold"
                    android:textColor="#2dd4bf"
                    android:gravity="center"
                    android:background="@drawable/glass_card_bg"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="4"/>
                <TextView
                    android:textColor="#e2e8f0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="It will close automatically ☺️"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:background="@drawable/step_item_bg"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">
                <TextView
                    android:textStyle="bold"
                    android:textColor="#2dd4bf"
                    android:gravity="center"
                    android:background="@drawable/glass_card_bg"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="5"/>
                <TextView
                    android:textColor="#e2e8f0"
                    android:id="@+id/inst_time_txt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enjoy ad-free streaming for next 12 hours ��"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:id="@+id/btnHowToOpenAds"
            android:background="@drawable/glass_card_bg"
            android:padding="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="18dp">
            <TextView
                android:textSize="18sp"
                android:textColor="#ffffff"
                android:gravity="center"
                android:background="@drawable/glass_card_bg"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="?"/>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp">
                <TextView
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="How to Open Ads?"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="#94a3b8"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Watch tutorial if ads don&apos;t open"/>
            </LinearLayout>
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_media_play"
                app:tint="#ff3358"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:id="@+id/btnJoinTelegram"
            android:background="@drawable/glass_tg_card_bg"
            android:padding="16dp"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">
            <ImageView
                android:gravity="center"
                android:background="@drawable/glass_card_bg"
                android:padding="5dp"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_telegram"
                app:tint="#24a1de"/>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp">
                <TextView
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Join us on Telegram"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/light_white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Get updates, support &amp; more"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
