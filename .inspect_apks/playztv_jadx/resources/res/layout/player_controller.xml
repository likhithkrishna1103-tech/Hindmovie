<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/player_controls"
    android:background="#6e000000"
    android:paddingLeft="@dimen/_10sdp"
    android:paddingRight="@dimen/_10sdp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/top_btns_lay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">
            <ImageButton
                android:id="@+id/btn_back"
                android:background="@drawable/button_back"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="@dimen/_30sdp"
                android:layout_height="@dimen/_30sdp"
                android:foreground="?attr/selectableItemBackground"
                android:src="@drawable/ic_back"
                android:layout_marginEnd="17dp"
                app:tint="@android:color/white"/>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:ellipsize="end"
                android:id="@+id/title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="5dp"
                android:maxLines="1"
                android:layout_weight="1"/>
            <ImageButton
                android:id="@+id/btn_mute"
                android:background="@drawable/button_back"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="@dimen/_30sdp"
                android:layout_height="@dimen/_30sdp"
                android:foreground="?attr/selectableItemBackground"
                android:src="@drawable/volume_up_24px"
                android:layout_marginEnd="@dimen/_10sdp"/>
            <ImageButton
                android:id="@+id/btn_lock_unlock"
                android:background="@drawable/button_back"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="@dimen/_30sdp"
                android:layout_height="@dimen/_30sdp"
                android:foreground="?attr/selectableItemBackground"
                android:src="@drawable/ic_unlock"/>
        </LinearLayout>
        <FrameLayout
            android:id="@+id/controller_links_lay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/top_btns_lay"/>
    </RelativeLayout>
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@+id/bottom_controller"
        android:paddingTop="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@+id/timer_bar_ly"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent">
        <ImageButton
            android:id="@+id/resize_mode"
            android:background="@drawable/button_back"
            android:focusable="true"
            android:clickable="true"
            android:src="@drawable/mode_fill"
            style="@style/ExoStyledControls.Button.Bottom"/>
        <ImageButton
            android:id="@+id/btn_pip"
            android:background="@drawable/button_back"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="@dimen/_30sdp"
            android:layout_height="@dimen/_30sdp"
            android:layout_margin="@dimen/_5sdp"
            android:foreground="?attr/selectableItemBackground"
            android:src="@drawable/pip_mode"
            app:tint="@android:color/white"/>
        <ImageButton
            android:id="@+id/exo_rew"
            android:background="@drawable/button_back"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="@dimen/_30sdp"
            android:layout_height="@dimen/_30sdp"
            android:layout_margin="@dimen/_5sdp"
            android:foreground="?attr/selectableItemBackground"
            android:src="@drawable/exo_icon_rewind"
            app:tint="@android:color/white"/>
        <ImageButton
            android:id="@+id/exo_play"
            android:background="@drawable/button_back"
            android:focusable="true"
            android:visibility="gone"
            android:clickable="true"
            android:layout_width="@dimen/_30sdp"
            android:layout_height="@dimen/_30sdp"
            android:layout_margin="@dimen/_5sdp"
            android:foreground="?attr/selectableItemBackground"
            android:src="@drawable/exo_icon_play"
            app:tint="@android:color/white"/>
        <ImageButton
            android:id="@+id/exo_pause"
            android:background="@drawable/button_back"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="@dimen/_30sdp"
            android:layout_height="@dimen/_30sdp"
            android:layout_margin="@dimen/_5sdp"
            android:foreground="?attr/selectableItemBackground"
            android:src="@drawable/exo_icon_pause"
            app:tint="@android:color/white"/>
        <ImageButton
            android:id="@+id/exo_ffwd"
            android:background="@drawable/button_back"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="@dimen/_30sdp"
            android:layout_height="@dimen/_30sdp"
            android:layout_margin="@dimen/_5sdp"
            android:foreground="?attr/selectableItemBackground"
            android:src="@drawable/exo_icon_fastforward"
            app:tint="@android:color/white"/>
        <ImageButton
            android:id="@+id/btn_settings"
            android:background="@drawable/button_back"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="@dimen/_30sdp"
            android:layout_height="@dimen/_30sdp"
            android:layout_margin="@dimen/_5sdp"
            android:foreground="?attr/selectableItemBackground"
            android:src="@drawable/ic_settings"
            app:tint="@android:color/white"/>
        <ImageButton
            android:id="@+id/fullscreen"
            android:background="@drawable/button_back"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="@dimen/_30sdp"
            android:layout_height="@dimen/_30sdp"
            android:layout_margin="@dimen/_5sdp"
            android:foreground="?attr/selectableItemBackground"
            android:src="@drawable/exo_ic_fullscreen_enter"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/timer_bar_ly"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="3dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent">
        <TextView
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#ffbebebe"
            android:id="@+id/exo_position"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"/>
        <androidx.media3.ui.DefaultTimeBar
            android:id="@+id/exo_progress"
            android:focusable="true"
            android:layout_width="0dp"
            android:layout_height="26dp"
            android:layout_weight="1"/>
        <TextView
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#ffbebebe"
            android:id="@+id/exo_duration"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"/>
    </LinearLayout>
    <ImageButton
        android:id="@+id/btn_prev"
        android:background="@drawable/button_back"
        android:focusable="true"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="@dimen/_30sdp"
        android:layout_height="@dimen/_30sdp"
        android:foreground="?attr/selectableItemBackground"
        android:src="@drawable/media3_icon_previous"
        android:scaleType="fitXY"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <ImageButton
        android:id="@+id/btn_next"
        android:background="@drawable/button_back"
        android:focusable="true"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="@dimen/_30sdp"
        android:layout_height="@dimen/_30sdp"
        android:foreground="?attr/selectableItemBackground"
        android:src="@drawable/media3_icon_next"
        android:scaleType="fitXY"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
