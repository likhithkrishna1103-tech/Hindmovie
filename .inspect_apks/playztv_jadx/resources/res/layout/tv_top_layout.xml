<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:background="@color/dark"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="19.5dp"
    android:paddingEnd="19.5dp">
    <ImageView
        android:id="@+id/search_img"
        android:focusable="true"
        android:visibility="gone"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:alpha="0.7"
        android:layout_marginEnd="@dimen/_5sdp"
        app:srcCompat="@drawable/search_24px"/>
    <EditText
        android:textColor="@color/white"
        android:textColorHint="#ffbbbbbb"
        android:id="@+id/search_view"
        android:focusable="true"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Search"/>
    <ImageButton
        android:id="@+id/menu_btn"
        android:padding="6.5dp"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/tv_btn_back"
        app:srcCompat="@drawable/menu_24px"/>
    <com.google.android.material.button.MaterialButton
        android:textColor="@color/white"
        android:id="@+id/events_btn"
        android:focusable="true"
        android:layout_width="wrap_content"
        android:layout_height="45dp"
        android:text="Live Events"
        android:textAllCaps="false"
        android:layout_marginStart="@dimen/_5sdp"
        android:elevation="0dp"
        android:backgroundTint="@color/tv_btn_back"/>
    <com.google.android.material.button.MaterialButton
        android:textColor="@color/white"
        android:id="@+id/cats_btn"
        android:focusable="true"
        android:layout_width="wrap_content"
        android:layout_height="45dp"
        android:text="Categories"
        android:textAllCaps="false"
        android:layout_marginStart="@dimen/_5sdp"
        android:elevation="0dp"
        android:backgroundTint="@color/tv_btn_back"/>
    <com.google.android.material.button.MaterialButton
        android:textColor="@color/white"
        android:id="@+id/sports_btn"
        android:focusable="true"
        android:layout_width="wrap_content"
        android:layout_height="45dp"
        android:text="Sports"
        android:textAllCaps="false"
        android:layout_marginStart="@dimen/_5sdp"
        android:elevation="0dp"
        android:backgroundTint="@color/tv_btn_back"/>
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1"/>
    <TextView
        android:textSize="19sp"
        android:textStyle="bold"
        android:ellipsize="end"
        android:id="@+id/title_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/_10sdp"
        android:layout_marginRight="@dimen/_10sdp"
        android:text="@string/app_name"
        android:singleLine="true"/>
    <ImageButton
        android:id="@+id/fav_btn"
        android:padding="@dimen/_5sdp"
        android:focusable="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAllCaps="false"
        android:layout_marginEnd="5dp"
        android:backgroundTint="@color/tv_btn_back"
        app:srcCompat="@drawable/baseline_star_24"/>
    <ImageButton
        android:id="@+id/refresh_btn"
        android:padding="@dimen/_5sdp"
        android:focusable="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAllCaps="false"
        android:layout_marginEnd="5dp"
        android:backgroundTint="@color/tv_btn_back"
        app:srcCompat="@drawable/refresh_24px"/>
    <ImageButton
        android:id="@+id/search_btn"
        android:padding="@dimen/_5sdp"
        android:focusable="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAllCaps="false"
        android:layout_marginEnd="5dp"
        android:backgroundTint="@color/tv_btn_back"
        app:srcCompat="@drawable/search_24px"/>
</LinearLayout>
