<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/player_controls"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:id="@+id/exo_controls_background"
        android:background="@color/exo_black_opacity_30"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/custom_controls"
        android:background="@color/cb"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:gravity="end|center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/top_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageButton
                    android:id="@+id/exo_back"
                    android:src="@drawable/ic_back"
                    app:tint="@color/white"
                    style="@style/ExoStyledControls.Button.Bottom"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/_5sdp"
                    android:layout_weight="1">
                    <FrameLayout
                        android:id="@+id/controllerLinksLay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <ImageButton
                    android:id="@+id/exo_pip"
                    android:padding="13dp"
                    android:src="@drawable/pip_mode"
                    android:layout_marginEnd="-8dp"
                    style="@style/ExoStyledControls.Button.Bottom"/>
                <ImageButton
                    android:id="@+id/exo_settings"
                    android:src="@drawable/ic_settings"
                    android:layout_marginEnd="-8dp"
                    app:tint="@color/white"
                    style="@style/ExoStyledControls.Button.Bottom"/>
                <ImageButton
                    android:id="@+id/exo_mute"
                    android:src="@drawable/volume_up_24px"
                    android:layout_marginEnd="-8dp"
                    app:tint="@color/white"
                    style="@style/ExoStyledControls.Button.Bottom"/>
                <ImageButton
                    android:id="@+id/exo_lock"
                    android:src="@drawable/ic_unlock"
                    app:tint="@color/white"
                    style="@style/ExoStyledControls.Button.Bottom"/>
            </LinearLayout>
            <ImageButton
                android:id="@+id/exo_unlock"
                android:visibility="gone"
                android:src="@drawable/ic_lock"
                app:tint="@color/white"
                style="@style/ExoStyledControls.Button.Bottom"/>
        </LinearLayout>
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:id="@+id/bottom_controller"
            android:paddingTop="4dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="end|center_vertical"
                android:orientation="horizontal"
                android:id="@+id/right_ly"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/adjust_btn"
                    android:src="@drawable/mode_fill"
                    android:layout_marginEnd="-8dp"
                    style="@style/ExoStyledControls.Button.Bottom"/>
                <FrameLayout
                    android:id="@+id/exo_exo_rew_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="-8dp">
                    <ImageButton
                        android:id="@+id/exo_rew"
                        style="@style/ExoMediaButton.Rewind"/>
                </FrameLayout>
            </LinearLayout>
            <ImageButton
                android:id="@+id/exo_play"
                android:padding="@dimen/_7sdp"
                android:layout_marginEnd="-8dp"
                style="@style/ExoStyledControls.Button.Center.PlayPause"/>
            <ImageButton
                android:id="@+id/exo_pause"
                android:padding="@dimen/_7sdp"
                android:visibility="gone"
                android:src="@drawable/exo_styled_controls_pause"
                android:layout_marginEnd="-8dp"
                style="@style/ExoStyledControls.Button.Center.PlayPause"/>
            <LinearLayout
                android:gravity="start|center_vertical"
                android:orientation="horizontal"
                android:id="@+id/left_ly"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <FrameLayout
                    android:id="@+id/exo_ffwd_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="-8dp">
                    <ImageButton
                        android:id="@+id/exo_ffwd"
                        style="@style/ExoMediaButton.FastForward"/>
                </FrameLayout>
                <ImageButton
                    android:id="@+id/exo_fullscreen_btn"
                    android:src="@drawable/exo_ic_fullscreen_enter"
                    style="@style/ExoStyledControls.Button.Bottom"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/timer_bar_ly"
            android:paddingLeft="@dimen/_8sdp"
            android:paddingRight="@dimen/_8sdp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/_3sdp">
            <TextView
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#ffbebebe"
                android:id="@+id/exo_position"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"/>
            <androidx.media3.ui.DefaultTimeBar
                android:id="@+id/exo_progress"
                android:layout_width="0dp"
                android:layout_height="26dp"
                android:layout_weight="1"/>
            <TextView
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#ffbebebe"
                android:id="@+id/exo_duration"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"/>
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
